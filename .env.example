# Conexão com o banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:porta/banco?sslmode=require"

# Segredo para assinatura de Tokens JWT de sessão do Admin
JWT_SECRET="sua_chave_secreta_jwt"

# URL pública da aplicação (usada para metadados OG e webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Credenciais do gateway Mercado Pago (Opcional - preencher para habilitar pagamentos reais)
# MERCADO_PAGO_ACCESS_TOKEN=""
# MERCADO_PAGO_PUBLIC_KEY=""
# MERCADO_PAGO_WEBHOOK_SECRET=""

# API PushinPay (Novo PIX)
PUSHINPAY_TOKEN=""

